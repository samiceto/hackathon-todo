# Database Configuration
# Neon Serverless PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require

# Authentication
# Shared secret for JWT token signing/verification (MUST match frontend)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here

# CORS Configuration
# Allowed origins for cross-origin requests (JSON array format)
# Development: ["http://localhost:3000"]
# Production: ["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# Application Environment
# Set to True for development, False for production
DEBUG=True

# Step 3: OpenAI Configuration
# OpenAI API key for Agents SDK
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Step 3: MCP Server Configuration
# URL where MCP server is accessible (same FastAPI process by default)
MCP_SERVER_URL=http://localhost:8000/mcp

# Step 3: Conversation Configuration
# Maximum number of messages to include in conversation context
MAX_CONVERSATION_CONTEXT=50
