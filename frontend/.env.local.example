# Better Auth Configuration
# Shared secret for JWT token signing/verification (MUST match backend)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here

# Better Auth URL - Frontend application URL
# Development: http://localhost:3000
# Production: https://yourdomain.com
BETTER_AUTH_URL=http://localhost:3000

# Database Configuration (Better Auth needs this for user management)
# Neon Serverless PostgreSQL connection string (SAME as backend)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require

# Backend API Configuration
# NEXT_PUBLIC_ prefix makes this variable accessible in the browser
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
